DATABASE_URL=postgres://pmgo:pmgo@localhost:5432/pm_go
# Optional: used only by integration tests that exercise real Postgres.
# DATABASE_URL_TEST=postgres://pmgo:pmgo@localhost:5432/pm_go_test
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=pm-go-worker
API_PORT=3001
ANTHROPIC_API_KEY=
PLANNER_MODEL=claude-sonnet-4-6
PLANNER_EXECUTOR_MODE=stub
PLAN_ARTIFACT_DIR=./artifacts/plans
IMPLEMENTER_EXECUTOR_MODE=stub
WORKTREE_ROOT=./.worktrees
IMPLEMENTER_MODEL=claude-sonnet-4-6
# Phase 4 — reviewer runner config. stub mode consumes REVIEWER_SMOKE_SEQUENCE.
REVIEWER_EXECUTOR_MODE=stub
REVIEWER_MODEL=claude-sonnet-4-6
REVIEWER_BUDGET_USD_CAP=1.0
REVIEWER_MAX_TURNS_CAP=40
# Comma-separated list of stub reviewer outcomes consumed in order across
# calls. Entries are one of: pass | changes_requested | blocked. Only
# honored when REVIEWER_EXECUTOR_MODE=stub.
REVIEWER_SMOKE_SEQUENCE=changes_requested,pass
